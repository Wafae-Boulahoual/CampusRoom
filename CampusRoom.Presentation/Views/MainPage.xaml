<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CampusRoom.Presentation.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Grid Grid.Row="0">
                <Image
                Source="studyroom.png"
                Aspect="AspectFill" />
            </Grid>

            <Label
                Text="Campus Nyköping"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Style="{StaticResource Headline}" />

            <Entry
                x:Name="Email"
                Placeholder="E-Post"
                Keyboard="Email"/>

            <Entry
                x:Name="Password"
                Placeholder="Lösenord"
                IsPassword="True"/>
                
             <Button
                Text="Logga in"
                Clicked="OnLoginButtonClicked"/>

            <Label
                x:Name="Error"
                TextColor="Red"
                FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
